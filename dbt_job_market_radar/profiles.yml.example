job_market_radar:
  target: dev
  outputs:
    dev:
      type: postgres
      host: "{{ env_var('POSTGRES_HOST', '127.0.0.1') }}"
      port: "{{ env_var('POSTGRES_PORT', '5433') | int }}"
      user: "{{ env_var('POSTGRES_USER', 'job_market_radar') }}"
      password: "{{ env_var('POSTGRES_PASSWORD', 'change_me') }}"
      dbname: "{{ env_var('POSTGRES_DB', 'job_market_radar') }}"
      schema: public
      threads: "{{ env_var('DBT_THREADS', '1') | int }}"
      connect_timeout: 10
      keepalives_idle: 0
